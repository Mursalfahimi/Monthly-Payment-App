<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="284dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:contentDescription="@string/app_image"
            android:src="@drawable/loan_image" />

        <TextView
            android:text="@string/principal_label"
            android:textSize="18sp"
            android:textColor="@color/text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/editPrincipal"
            android:layout_width="match_parent"
            android:layout_height="59dp"
            android:autofillHints=""
            android:hint="@string/principal_hint"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="@string/rate_label"
            android:textColor="@color/text_color"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/editRate"
            android:layout_width="367dp"
            android:layout_height="69dp"
            android:autofillHints=""
            android:hint="@string/rate_hint"
            android:inputType="numberDecimal"/>

        <TextView
            android:text="@string/term_label"
            android:textSize="18sp"
            android:textColor="@color/text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup
            android:id="@+id/radioGroupYears"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/radio10"
                android:text="@string/years_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioButton
                android:id="@+id/radio15"
                android:text="@string/years_15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioButton
                android:id="@+id/radio30"
                android:text="@string/years_30"
                android:checked="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <Button
            android:id="@+id/buttonCompute"
            android:text="@string/compute_button"
            android:backgroundTint="@color/button_color"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/textResult"
            android:layout_width="344dp"
            android:layout_height="77dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/result_default"
            android:textColor="@color/result_color"
            android:textSize="22sp"/>

    </LinearLayout>
</ScrollView>

